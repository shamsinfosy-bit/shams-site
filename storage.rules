r0
ules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // الملفات العامة للقراءة فقط
    match /{allPaths=**} {
      allow read: if true;
    }

    // رفع المحتوى مسموح فقط للمستخدمين المسجلين
    match /{category}/{userId}/{fileName} {

      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 500 * 1024 * 1024;

      allow read: if true;
    }
  }
}
